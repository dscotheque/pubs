# Slack Incoming Webhook URL for publication notifications
# See README.md for instructions on creating a webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Google Scholar alert ingestion (Gmail IMAP)
# Requires a Gmail App Password (not your regular password)
# See README.md for setup instructions
SCHOLAR_EMAIL=your.email@gmail.com
SCHOLAR_PASSWORD="xxxx xxxx xxxx xxxx"
